    {name = "Legend Gym (1M)",          dur = 1000000},
    {name = "Muscle King (5M)",         dur = 5000000},
    {name = "Ancient Jungle (10M)",     dur = 10000000},
}

for _, rock in ipairs(rockDurList) do
    rockSec:AddSwitch("Farm " .. rock.name, function(s)
        if s then
            selectedRockDurability = rock.dur
            states.rockFarmActive = true
        else
            if selectedRockDurability == rock.dur then
                states.rockFarmActive = false
                selectedRockDurability = 0
            end
        end
    end)
end

rockSec:AddButton("STOP Rock Farming", function()
    states.rockFarmActive = false
    selectedRockDurability = 0
end)

-- Rock farm loop (runs always, checks state)
task.spawn(function()
    while getgenv().NexusRunning do
        if not states.rockFarmActive or selectedRockDurability <= 0 then
            task.wait(0.8) continue
        end

        pcall(function()
            local char = LocalPlayer.Character
            if not char or char.Humanoid.Health <= 0 then task.wait(1.5) return end

            local durVal = LocalPlayer:FindFirstChild("Durability")
            if not durVal or durVal.Value < selectedRockDurability then task.wait(0.6) return end

            equipTool("Punch")

            for _, obj in ipairs(workspace.machinesFolder:GetDescendants()) do
                if obj.Name == "neededDurability" and obj:IsA("IntValue") and obj.Value == selectedRockDurability then
                    local rock = obj.Parent:FindFirstChild("Rock")
                    if rock and rock:IsA("BasePart") then
                        local rh = char:FindFirstChild("RightHand")
                        local lh = char:FindFirstChild("LeftHand")
                        if rh then
                            firetouchinterest(rock, rh, 0) task.wait(0.03) firetouchinterest(rock, rh, 1)
                        end
                        if lh then
                            firetouchinterest(rock, lh, 0) task.wait(0.03) firetouchinterest(rock, lh, 1)
                        end
                        if muscleEvent then
                            muscleEvent:FireServer("punch", "leftHand")
                            muscleEvent:FireServer("punch", "rightHand")
                        end
                    end
                end
            end
        end)
        task.wait(0.18)
    end
end)

