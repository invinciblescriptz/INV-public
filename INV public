end)

rebFolder:AddInput("Target Rebirths", function(val)
    local n = tonumber(val)
    if n and n > 0 then targetRebirths = n end
end)

rebFolder:AddSwitch("Auto Rebirth → Target", function(s)
    states.AutoRebirthTarget = s
    if s and rebirthRemote then
        task.spawn(function()
            while states.AutoRebirthTarget and getgenv().NexusRunning do
                pcall(function()
                    local rb = LocalPlayer.leaderstats and LocalPlayer.leaderstats:FindFirstChild("Rebirths")
                    if rb and rb.Value >= targetRebirths then
                        states.AutoRebirthTarget = false
                        return
                    end
                    rebirthRemote:InvokeServer("rebirthRequest")
                end)
                task.wait(0.14)
            end
        end)
    end
end)

