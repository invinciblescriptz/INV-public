-- INV Key System (fixed version - key: INVxONTOP)

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local player = Players.LocalPlayer

local CORE_KEY = "INVxONTOP"

-- Try CoreGui first, fallback to PlayerGui
local guiParent = game:FindService("CoreGui") or player:WaitForChild("PlayerGui", 8)
if not guiParent then
    warn("[INV] Cannot find valid GUI parent → aborting")
    return
end

local sg = Instance.new("ScreenGui")
sg.Name = "INVKeyGUI"
sg.ResetOnSpawn = false
sg.Parent = guiParent

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 380, 0, 280)
frame.Position = UDim2.new(0.5, -190, 0.5, -140)
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BorderSizePixel = 0
frame.Parent = sg

-- Simple shadow
local shadow = Instance.new("Frame")
shadow.Size = UDim2.new(1, 14, 1, 14)
shadow.Position = UDim2.new(0, -7, 0, -7)
shadow.BackgroundColor3 = Color3.new(0,0,0)
shadow.BackgroundTransparency = 0.65
shadow.ZIndex = -1
shadow.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 50)
title.Position = UDim2.new(0, 0, 0, 20)
title.BackgroundTransparency = 1
title.Text = "INV Key System"
title.TextColor3 = Color3.new(1,1,1)
title.Font = Enum.Font.GothamBold
title.TextSize = 26
title.TextXAlignment = Enum.TextXAlignment.Center
title.Parent = frame

local sub = Instance.new("TextLabel")
sub.Size = UDim2.new(1, 0, 0, 20)
sub.Position = UDim2.new(0, 0, 0, 70)
sub.BackgroundTransparency = 1
sub.Text = "by invincible • Key: INVxONTOP"
sub.TextColor3 = Color3.fromRGB(160, 160, 160)
sub.Font = Enum.Font.Gotham
sub.TextSize = 14
sub.TextXAlignment = Enum.TextXAlignment.Center
sub.Parent = frame

local input = Instance.new("TextBox")
input.Size = UDim2.new(0, 260, 0, 38)
input.Position = UDim2.new(0.5, -130, 0, 110)
input.AnchorPoint = Vector2.new(0.5, 0)
input.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
input.BorderSizePixel = 0
input.TextColor3 = Color3.new(1,1,1)
input.PlaceholderText = "Paste key here..."
input.PlaceholderColor3 = Color3.fromRGB(120,120,120)
input.Font = Enum.Font.Gotham
input.TextSize = 16
input.ClearTextOnFocus = false
input.Parent = frame

local btn = Instance.new("TextButton")
btn.Size = UDim2.new(0, 260, 0, 48)
btn.Position = UDim2.new(0.5, -130, 0, 165)
btn.AnchorPoint = Vector2.new(0.5, 0)
btn.BackgroundColor3 = Color3.fromRGB(0, 102, 204)
btn.BorderSizePixel = 0
btn.Font = Enum.Font.GothamBold
btn.Text = "VERIFY KEY"
btn.TextColor3 = Color3.new(1,1,1)
btn.TextSize = 18
btn.Parent = frame

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -40, 0, 30)
status.Position = UDim2.new(0, 20, 1, -45)
status.BackgroundTransparency = 1
status.Text = ""
status.TextColor3 = Color3.fromRGB(220, 80, 80)
status.Font = Enum.Font.Gotham
status.TextSize = 15
status.TextXAlignment = Enum.TextXAlignment.Center
status.Parent = frame

-- Hover effect
btn.MouseEnter:Connect(function()
    TweenService:Create(btn, TweenInfo.new(0.25), {BackgroundColor3 = Color3.fromRGB(0, 130, 255)}):Play()
end)
btn.MouseLeave:Connect(function()
    TweenService:Create(btn, TweenInfo.new(0.25), {BackgroundColor3 = Color3.fromRGB(0, 102, 204)}):Play()
end)

-- Simple fade-in
frame.BackgroundTransparency = 1
TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {BackgroundTransparency = 0}):Play()

-- The actual check
btn.MouseButton1Click:Connect(function()
    local key = input.Text:gsub("%s+", ""):upper()  -- remove spaces, make uppercase
    
    if key == CORE_KEY or key == "INVXONTOP" then
        status.Text = "Key valid • Loading..."
        status.TextColor3 = Color3.fromRGB(80, 220, 100)
        btn.Text = "LOADING..."
        btn.Active = false
        
        task.wait(0.6)
        
        local url = "https://github.com/invinciblescriptz/INV-clan-script/blob/main/INV.lua.txt"
        
        local success, errOrResult = pcall(function()
            local code = game:HttpGet(url, true)
            return loadstring(code)()
        end)
        
        if success then
            status.Text = "Script loaded!"
            status.TextColor3 = Color3.fromRGB(100, 255, 140)
            task.wait(1.2)
            sg:Destroy()
        else
            status.Text = "Load failed: " .. tostring(errOrResult):sub(1,80) .. "..."
            status.TextColor3 = Color3.fromRGB(255, 90, 90)
            warn("[INV] Loadstring error: " .. tostring(errOrResult))
            btn.Text = "TRY AGAIN"
            btn.Active = true
        end
        
    else
        status.Text = "Invalid key"
        status.TextColor3 = Color3.fromRGB(255, 90, 90)
        TweenService:Create(input, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 30, 30)}):Play()
        task.delay(1.4, function()
            TweenService:Create(input, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
            if status.Text == "Invalid key" then status.Text = "" end
        end)
    end
end)

print("[INV Key System] Ready - use key: INVxONTOP")
