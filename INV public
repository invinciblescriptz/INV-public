-- Tween service
local TweenService = game:GetService("TweenService")
local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

local function tween(obj, props)
    TweenService:Create(obj, tweenInfo, props):Play()
end

-- Simple hover effect for button
submitButton.MouseEnter:Connect(function()
    tween(submitButton, {BackgroundColor3 = Color3.fromRGB(0, 150, 255)})
end)

submitButton.MouseLeave:Connect(function()
    tween(submitButton, {BackgroundColor3 = Color3.fromRGB(0, 120, 215)})
end)

-- The correct key (hardcoded)
local CORRECT_KEY = "INVxONTOP"

-- Main script URL
local mainScriptUrl = "https://raw.githubusercontent.com/invinciblescriptz/INV-clan-script/refs/heads/main/INV.lua.txt"

-- When button is clicked
submitButton.MouseButton1Click:Connect(function()
    local entered = inputBox.Text:gsub("%s+", "") -- remove all whitespace
    
    if entered == CORRECT_KEY then
        -- Success
        tween(submitButton, {BackgroundColor3 = Color3.fromRGB(0, 200, 80)})
        tween(inputBox,   {BackgroundColor3 = Color3.fromRGB(40, 90, 40)})
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        statusLabel.Text = "Key accepted! Loading script..."
        
        submitButton.Text = "Loading..."
        submitButton.Active = false
        
        task.wait(0.8)
        
        -- Load the real script
        local success, result = pcall(function()
            return loadstring(game:HttpGet(mainScriptUrl, true))()
        end)
        
        if success then
            statusLabel.Text = "Script loaded successfully!"
            tween(statusLabel, {TextColor3 = Color3.fromRGB(120, 255, 120)})
            task.wait(1.2)
            screenGui:Destroy() -- optional: remove key gui after success
        else
            statusLabel.Text = "Failed to load main script"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            warn("Loadstring failed: " .. tostring(result))
            submitButton.Text = "Try Again"
            submitButton.Active = true
        end
        
    else
        -- Wrong key
        tween(inputBox, {BackgroundColor3 = Color3.fromRGB(100, 30, 30)})
        tween(submitButton, {BackgroundColor3 = Color3.fromRGB(180, 40, 40)})
        statusLabel.Text = "Invalid key. Try again."
        statusLabel.TextColor3 = Color3.fromRGB(255, 90, 90)
        
        task.delay(1.8, function()
            if statusLabel.Text == "Invalid key. Try again." then
                tween(inputBox,   {BackgroundColor3 = Color3.fromRGB(45, 45, 45)})
                tween(submitButton, {BackgroundColor3 = Color3.fromRGB(0, 120, 215)})
                statusLabel.Text = ""
            end
        end)
    end
end)

